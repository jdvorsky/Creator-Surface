{
  "name": "creator-surface",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=18.18.0",
    "npm": ">=9"
  },
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js --host 127.0.0.1",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "lint": "node ./node_modules/eslint/bin/eslint.js . --ext .ts,.tsx,.js,.cjs,.mjs",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "test:e2e": "node ./node_modules/@playwright/test/cli.js test",
    "build": "node ./node_modules/typescript/bin/tsc --noEmit && node ./node_modules/vite/bin/vite.js build",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build",
    "check:full": "npm run check && npm run test:e2e",
    "check:perf": "node ./scripts/check-performance-budgets.mjs",
    "check:release": "npm run check:full && npm audit && npm audit --omit=dev && npm run check:perf"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.1",
    "@lezer/json": "^1.0.3",
    "@uiw/react-codemirror": "^4.23.13",
    "immer": "^10.1.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^2.1.8",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^18.19.130",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.16",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
